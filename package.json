{
  "name": "screenie",
  "version": "1.0.0",
  "description": "Desktop screenshot timelapse application — automatically captures your screen and generates timelapse videos",
  "main": "src/main/main.js",
  "scripts": {
    "start": "electron .",
    "test": "node --test test/*.test.js",
    "build": "electron-builder --win --publish never",
    "build:portable": "electron-builder --win portable --publish never"
  },
  "keywords": [
    "screenshot",
    "timelapse",
    "screen-capture",
    "activity-tracker",
    "electron",
    "windows",
    "ffmpeg"
  ],
  "author": "StillPillWill",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/StillPillWill/Screenie.git"
  },
  "bugs": {
    "url": "https://github.com/StillPillWill/Screenie/issues"
  },
  "homepage": "https://github.com/StillPillWill/Screenie#readme",
  "dependencies": {
    "ffmpeg-static": "^5.2.0",
    "fluent-ffmpeg": "^2.1.3",
    "koffi": "^2.9.0"
  },
  "devDependencies": {
    "electron": "^31.0.0",
    "electron-builder": "^25.0.0"
  },
  "build": {
    "appId": "com.stillpillwill.screenie",
    "productName": "Screenie",
    "copyright": "Copyright © 2026 StillPillWill",
    "directories": {
      "output": "dist"
    },
    "files": [
      "src/**/*",
      "node_modules/**/*"
    ],
    "extraResources": [],
    "win": {
      "icon": "src/renderer/assets/icon.ico",
      "target": [
        {
          "target": "nsis",
          "arch": ["x64"]
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowElevation": true,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Screenie",
      "installerIcon": "src/renderer/assets/icon.ico",
      "uninstallerIcon": "src/renderer/assets/icon.ico",
      "installerHeaderIcon": "src/renderer/assets/icon.ico",
      "deleteAppDataOnUninstall": false,
      "runAfterFinish": true
    }
  }
}
